[user]
	name = Anish Athalye
	email = me@anishathalye.com

[github]
	user = anishathalye

[core]
	pager = `brew --prefix git`/share/git-core/contrib/diff-highlight/diff-highlight | less

[diff "scpt"]
	textconv = osadecompile
	binary=true

[core]
    fsmonitor = true

[feature]
    manyFiles = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[maintenance]
	repo = ~/Documents/Anish/src/anytitan
	repo = ~/Documents/Anish/src/everysphere
	repo = ~/Documents/Anish/src/xai
